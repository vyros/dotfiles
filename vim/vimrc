" ============================================================
" PLUGINS
" ============================================================
call plug#begin('~/.vim/plugged')

Plug 'morhetz/gruvbox'                                       " colorscheme
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }         " fuzzy search
Plug 'junegunn/fzf.vim'
Plug 'yegappan/lsp'                                          " LSP (Vim9Script)
Plug 'tpope/vim-fugitive'                                    " git commands
Plug 'airblade/vim-gitgutter'                                " git signs in gutter
Plug 'tpope/vim-commentary'                                  " gcc / gc{motion}
Plug 'jiangmiao/auto-pairs'                                  " auto-close brackets
Plug 'tpope/vim-surround'                                    " cs"' ds( ysiw)
Plug 'tpope/vim-vinegar'                                     " - to browse files

call plug#end()

" ============================================================
" GENERAL
" ============================================================
set nocompatible
filetype plugin indent on
syntax on

set encoding=utf-8
set hidden                     " switch buffers without saving
set autoread
set autowrite
set noswapfile
set history=5000
set updatetime=300

" indentation
set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=-1
set smarttab

" search
set incsearch
set hlsearch
set ignorecase
set smartcase
set showmatch

" display
set number
set relativenumber
set cursorline
set colorcolumn=112
set scrolloff=5
set wrap
set signcolumn=yes             " always show gutter (LSP diagnostics, git)
set list
set listchars=tab:>─,eol:¬,trail:\ ,nbsp:¤
set fillchars=vert:\│

" completion menu
set completeopt=menuone,noinsert,noselect
set shortmess+=c               " no "match X of Y" noise

" folds
set foldmethod=indent
set foldlevelstart=99          " all folds open by default

" splits open naturally
set splitright
set splitbelow

" persistent undo
set undofile
set undodir=~/.vim/undo//

if has('mouse')
    set mouse=a
endif

" ============================================================
" STATUSLINE
" ============================================================
set laststatus=2
set showmode
set wildmenu
set wildmode=longest:full,full

function! LspStatus() abort
    if !exists('*lsp#lsp#ErrorCount') | return '' | endif
    let l:counts = lsp#lsp#ErrorCount()
    if empty(l:counts) | return '' | endif
    let l:e = get(l:counts, 'Error', 0)
    let l:w = get(l:counts, 'Warning', 0)
    return l:e > 0 ? printf(' E:%d W:%d', l:e, l:w) : l:w > 0 ? printf(' W:%d', l:w) : ' OK'
endfunction

set statusline=
set statusline+=%f             " filename
set statusline+=\ %m%r         " modified/readonly
set statusline+=%=             " right side
set statusline+=%{exists('*FugitiveStatusline')?FugitiveStatusline():''} " git branch
set statusline+=%{LspStatus()} " LSP diagnostics
set statusline+=\ %Y           " filetype
set statusline+=\ %l:%c        " line:col
set statusline+=\ %p%%         " percentage

" ============================================================
" COLORSCHEME
" ============================================================
set termguicolors
set background=dark
let g:gruvbox_contrast_dark = 'medium'
let g:gruvbox_italic = 1
silent! colorscheme gruvbox

" ============================================================
" LEADER
" ============================================================
let mapleader = ' '
let maplocalleader = ' '

" ============================================================
" KEYMAPS — NAVIGATION
" ============================================================
" split navigation with Ctrl-hjkl
