nnoremap <A-k> :move .-2<CR>==
vnoremap <A-j> :move '>+1<CR>gv=gv
vnoremap <A-k> :move '<-2<CR>gv=gv

" ============================================================
" KEYMAPS — TERMINAL
" ============================================================
nnoremap <leader>tt :terminal<CR>
nnoremap <leader>tv :vertical terminal<CR>
tnoremap <Esc> <C-\><C-n>         " exit terminal mode with Esc

" ============================================================
" FZF
" ============================================================
let g:fzf_layout = { 'down': '40%' }

" fd pour lister les fichiers (Debian installe 'fdfind')
if executable('fd')
    let $FZF_DEFAULT_COMMAND = 'fd --type f --hidden --follow --exclude .git'
elseif executable('fdfind')
    let $FZF_DEFAULT_COMMAND = 'fdfind --type f --hidden --follow --exclude .git'
elseif executable('rg')
    let $FZF_DEFAULT_COMMAND = 'rg --files --hidden --follow --glob "!.git"'
endif

" preview avec bat si disponible
if executable('bat')
    let g:fzf_preview_window = ['right:50%', 'ctrl-/']
    command! -bang -nargs=? -complete=dir Files
        \ call fzf#vim#files(<q-args>, fzf#vim#with_preview(), <bang>0)
endif

nnoremap <leader>ff :Files<CR>
nnoremap <leader>fg :Rg<CR>
nnoremap <leader>fb :Buffers<CR>
nnoremap <leader>fh :History<CR>
nnoremap <leader>ft :BTags<CR>
nnoremap <leader>fl :BLines<CR>

" ============================================================
" LSP (yegappan/lsp — Vim9Script)
" ============================================================
function! s:SetupLsp()
    call LspOptionsSet(#{
        \ autoComplete: v:true,
        \ completionMatcher: 'fuzzy',
        \ showDiagWithSign: v:true,
        \ showDiagWithVirtualText: v:true,
        \ showInlayHints: v:true,
        \ highlightDiagInline: v:true,
        \ aleSupport: v:false,
        \ noNewlineInCompletion: v:true,
        \})

    let l:candidates = [
        \#{
        \  name: 'clangd',
        \  filetype: ['c', 'cpp', 'objc'],
        \  path: 'clangd',
        \  args: ['--background-index', '--clang-tidy'],
        \},
        \#{
        \  name: 'pylsp',
        \  filetype: ['python'],
        \  path: 'pylsp',
        \  args: [],
        \},
        \#{
        \  name: 'pyright',
        \  filetype: ['python'],
        \  path: 'pyright-langserver',
        \  args: ['--stdio'],
        \},
        \#{
        \  name: 'tsserver',
        \  filetype: ['javascript', 'typescript', 'javascriptreact', 'typescriptreact'],
        \  path: 'typescript-language-server',
        \  args: ['--stdio'],
        \},
        \#{
        \  name: 'rust-analyzer',
        \  filetype: ['rust'],
        \  path: 'rust-analyzer',
        \  args: [],
        \},
        \#{
        \  name: 'gopls',
        \  filetype: ['go'],
        \  path: 'gopls',
        \  args: [],
        \},
        \#{
        \  name: 'lua-language-server',
        \  filetype: ['lua'],
        \  path: 'lua-language-server',
        \  args: [],
        \},
        \#{
        \  name: 'docker-langserver',
        \  filetype: ['dockerfile'],
        \  path: expand('~/.local/bin/docker-langserver'),
        \  args: ['--stdio'],
        \},
        \#{
        \  name: 'docker-compose-langserver',
        \  filetype: ['yaml.docker-compose'],
        \  path: expand('~/.local/bin/docker-compose-langserver'),
        \  args: ['--stdio'],
        \},
        \]

    let l:servers = filter(l:candidates, 'executable(v:val.path)')
    if !empty(l:servers)
        call LspAddServer(l:servers)
    endif
endfunction

augroup LspSetup
    au!
    au User LspSetup call s:SetupLsp()
augroup END

" LSP keymaps (active only when LSP is attached)
augroup LspKeymaps
    au!
    au User LspAttached call s:LspKeymaps()
augroup END

function! s:LspKeymaps()
    " navigation
    nnoremap <buffer> gd          :LspGotoDefinition<CR>
    nnoremap <buffer> gD          :LspGotoDeclaration<CR>
    nnoremap <buffer> gr          :LspShowReferences<CR>
    nnoremap <buffer> gi          :LspGotoImpl<CR>
    nnoremap <buffer> gy          :LspGotoTypeDef<CR>
    " info
    nnoremap <buffer> K           :LspHover<CR>
    nnoremap <buffer> <leader>ls  :LspSymbolSearch<CR>
    nnoremap <buffer> <leader>lS  :LspWorkspaceSymbol<CR>
    " diagnostics
    nnoremap <buffer> [d          :LspDiagPrev<CR>
    nnoremap <buffer> ]d          :LspDiagNext<CR>
    nnoremap <buffer> <leader>ld  :LspDiagShow<CR>
    nnoremap <buffer> <leader>lq  :LspDiagCurrent<CR>
    " actions
    nnoremap <buffer> <leader>rn  :LspRename<CR>
    nnoremap <buffer> <leader>ca  :LspCodeAction<CR>
    nnoremap <buffer> <leader>lf  :LspFormat<CR>
    vnoremap <buffer> <leader>lf  :LspFormat<CR>
    " call hierarchy
    nnoremap <buffer> <leader>lc  :LspCallHierarchy<CR>
endfunction

