" ============================================================
" MARKDOWN — glow preview
" ============================================================
let s:glow_buf = -1

function! s:GlowPreview()
    if !executable('glow')
        echohl WarningMsg | echo 'glow non installé' | echohl None
        return
    endif
    let l:src_win = winnr()
    let l:file = expand('%:p')

    " Close existing glow window
    if s:glow_buf != -1 && bufexists(s:glow_buf)
        let l:glow_win = bufwinnr(s:glow_buf)
        if l:glow_win != -1
            execute l:glow_win . 'wincmd w'
            close!
        else
            execute 'bdelete! ' . s:glow_buf
        endif
    endif

    " Pass args as list — avoids shell quoting issues with term_start
    let l:job = term_start(
        \ ['glow', '--width', '78', '-s', 'dark', l:file],
        \ {'vertical': 1, 'term_name': 'glow: ' . expand('%:t')})
    let s:glow_buf = bufnr(l:job)
    execute l:src_win . 'wincmd w'
endfunction

nnoremap <leader>mg :call <SID>GlowPreview()<CR>

" Auto-refresh on save if glow is already open
augroup MarkdownGlow
    au!
    au BufWritePost *.md,*.markdown
        \ if s:glow_buf != -1 && bufexists(s:glow_buf) |
        \     call s:GlowPreview() |
        \ endif
augroup END

